#!/bin/sh
# Pre-push hook: crea tag vVERSION si no existe todavía
set -e

while read -r local_ref local_oid remote_ref remote_oid; do
    case "$remote_ref" in
        refs/heads/*) ;;
        *) continue ;;
    esac

    ROOT="$(git rev-parse --show-toplevel)"
    VERSION="$(cat "$ROOT/VERSION" 2>/dev/null | tr -d '[:space:]')"
    [ -z "$VERSION" ] && { echo "pre-push: VERSION is empty"; exit 1; }

    TAG="v${VERSION}"
    if git rev-parse "$TAG" >/dev/null 2>&1; then
        echo "pre-push: tag $TAG already exists"
    else
        echo "pre-push: creating tag $TAG"
        git tag "$TAG"
    fi
done
